# =========================================================================
# ACTIVECAMT PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' on your production server and fill out values
# =========================================================================

# -------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION
# -------------------------------------------------------------------------

# Database Connection (If using an external/managed database like AWS RDS or Supabase)
# If using the self-hosted docker-compose postgres DB, you can leave this commented out.
#
# 👉 HOW TO GET: 
#    - If using AWS RDS: Create a PostgreSQL instance in AWS RDS. Set it up inside a private VPC.
#      Copy the Endpoint URL. Format: postgresql://[user]:[password]@[endpoint]:5432/[database_name]?sslmode=require
#    - If using self-hosted Docker PostgreSQL: Keep this commented out and fill the variables below instead.
# DATABASE_URL=postgresql://username:securepassword@host:5432/dbname?sslmode=require

# Postgres Configuration (Used by the self-hosted docker-compose postgres container)
# 👉 HOW TO GET:
#    - POSTGRES_USER: Choose a custom admin username (e.g., activecamt_admin).
#    - POSTGRES_PASSWORD: Generate a secure password. Keep it complex to protect local data.
#    - POSTGRES_DB: Keep the default 'activecamt_prod' or change to your preferred DB name.
POSTGRES_USER=activecamt_admin
POSTGRES_PASSWORD=FILL_WITH_A_SUPER_SECURE_PASSWORD
POSTGRES_DB=activecamt_prod


# -------------------------------------------------------------------------
# 2. NEXTAUTH CONFIGURATION
# -------------------------------------------------------------------------

# NextAuth Configuration
# 👉 HOW TO GET:
#    - Open your terminal (macOS/Linux/Git Bash/WSL) and run the following command:
#      $ openssl rand -base64 33
#    - If you are on Windows PowerShell, run:
#      $ [Convert]::ToBase64String((1..33 | ForEach-Object { [byte](Get-Random -Minimum 0 -Maximum 256) }))
#    - Copy-paste the resulting string here. This is used to encrypt JWT session cookies securely.
AUTH_SECRET=FILL_WITH_SECURE_RANDOM_BASE64_KEY

# NextAuth Public Domain (Replace with your actual university domain)
# 👉 HOW TO GET:
#    - Put the exact URL where your application is hosted.
#    - It MUST be an HTTPS domain in production (e.g., https://activecamt.university.ac.th/api/auth)
#    - Make sure to append '/api/auth' at the end of the URL.
AUTH_URL=https://activecamt.university.ac.th/api/auth


# -------------------------------------------------------------------------
# 3. GOOGLE OAUTH CREDENTIALS (Authentication)
# -------------------------------------------------------------------------

# Google OAuth Credentials (Get these from Google Cloud Console)
# 👉 HOW TO GET (STEP-BY-STEP):
#    1. Go to the Google Cloud Console (https://console.cloud.google.com/).
#    2. Create a new project (e.g., "ActiveCAMT").
#    3. Navigate to "APIs & Services" > "OAuth consent screen":
#       - User Type: Select "Internal" (if you want to restrict it strictly to CMU members).
#       - App Name: Enter "ActiveCAMT".
#       - User support email: Select your CMU developer email.
#       - Developer contact information: Enter your CMU email.
#       - Scopes: Add '.../auth/userinfo.email' and '.../auth/userinfo.profile'.
#    4. Navigate to "APIs & Services" > "Credentials":
#       - Click "+ CREATE CREDENTIALS" and select "OAuth client ID".
#       - Application type: Select "Web application".
#       - Name: Enter "ActiveCAMT Production".
#       - Authorized JavaScript origins:
#         * Add your production domain: https://activecamt.university.ac.th
#       - Authorized redirect URIs (CRITICAL STEP):
#         * Add your domain callback URL: https://activecamt.university.ac.th/api/auth/callback/google
#       - Click "CREATE".
#    5. Google will display a popup containing:
#       - Your Client ID -> Copy-paste into 'AUTH_GOOGLE_ID' below.
#       - Your Client Secret -> Copy-paste into 'AUTH_GOOGLE_SECRET' below.
AUTH_GOOGLE_ID=FILL_WITH_YOUR_GOOGLE_CLIENT_ID
AUTH_GOOGLE_SECRET=FILL_WITH_YOUR_GOOGLE_CLIENT_SECRET


# -------------------------------------------------------------------------
# 4. SUPABASE STORAGE CONFIGURATION (For Serverless Environments like Vercel)
# -------------------------------------------------------------------------

# Supabase Credentials (Required for Vercel/Serverless deployment to handle file uploads)
# 👉 HOW TO GET:
#    1. Create a project on Supabase (https://supabase.com).
#    2. Create a public bucket named 'uploads' under the Storage tab.
#    3. Navigate to "Project Settings" > "API":
#       - Copy the 'Project URL' -> Paste as 'SUPABASE_URL'.
#       - Copy the 'service_role' key -> Paste as 'SUPABASE_SERVICE_ROLE_KEY'.
#       ⚠️ WARNING: Never expose the service_role key on the client-side.
SUPABASE_URL=FILL_WITH_YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=FILL_WITH_YOUR_SUPABASE_SERVICE_ROLE_KEY

