{
  "name": "activecamt",
  "version": "1.9.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "_comment_container": "*:container variants read DATABASE_URL from the process env (no .env file) — for running inside the Portainer/Swarm container console where env is injected by the stack.",
    "db:migrate:container": "tsx src/db/migrate.ts",
    "db:seed:container": "tsx src/db/seed.ts",
    "db:reset": "tsx --env-file=.env src/db/reset.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@electric-sql/pglite": "^0.5.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.107.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.42.2",
    "googleapis": "^173.0.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.14.0",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.185.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
